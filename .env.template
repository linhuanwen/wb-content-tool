# ============================================================
# WB Content Tool — 环境变量配置模板
# 复制此文件为 .env 并填入你的真实配置值
# ============================================================

# ---- AI 翻译服务配置 ----

# AI 服务商：openai / anthropic / deepseek / custom
TRANSLATE_API_PROVIDER=deepseek

# API 密钥（必填）
TRANSLATE_API_KEY=your-deepseek-api-key

# API 地址（可选，留空使用服务商默认地址；自定义服务商时必填）
TRANSLATE_API_BASE_URL=

# 翻译模型名称
TRANSLATE_MODEL=deepseek-v4-pro

# ---- 爬虫配置 ----

# 采集模式：playwright（浏览器自动化）或 scraperapi（付费 API，推荐）
CRAWLER_MODE=playwright

# 是否启用无头模式（true=后台运行，false=显示浏览器窗口便于调试）
# 仅 Playwright 模式生效
CRAWLER_HEADLESS=true

# 请求间隔（秒），避免触发亚马逊反爬机制
# 仅 Playwright 模式生效
CRAWLER_DELAY=5

# ScraperAPI Key（CRAWLER_MODE=scraperapi 时必填）
SCRAPERAPI_KEY=

# ---- Cloudflare R2 图片存储 ----

# R2 Access Key ID（必填，用于图片上传）
R2_ACCESS_KEY_ID=

# R2 Secret Access Key（必填）
R2_SECRET_ACCESS_KEY=

# R2 Account ID（32位 hex，必填）
R2_ACCOUNT_ID=

# R2 Bucket 名称
R2_BUCKET=wb-product-images

# R2 公开访问域名（必填，如 https://pub-xxx.r2.dev）
R2_PUBLIC_DOMAIN=

# ---- 图片处理配置 ----

# 图片本地存档目录
IMAGE_LOCAL_PATH=images

# 尺寸转换模式：pad（等比缩放+白边填充）/ outpainting（AI 扩展，后续支持）
IMAGE_RESIZE_MODE=pad

# 输出图片尺寸（宽×高）
IMAGE_OUTPUT_SIZE=900x1200

# ---- AI 修复 API ----

# AI 修复服务商
IMAGE_REPAIR_PROVIDER=replicate

# AI 修复 API Key（必填，用于图片文字擦除）
IMAGE_REPAIR_API_KEY=

# AI 修复模型
IMAGE_REPAIR_MODEL=tencentarc/gfpgan

# ---- 重试与超时 ----

# 每步骤最大重试次数
STEP_MAX_RETRIES=3

# 每步骤超时（秒）
STEP_TIMEOUT=60

# 重试退避底数
RETRY_BACKOFF_BASE=2
